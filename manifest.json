{
  "manifest_version": 3,
  "name": "Filtr Grup PK (Iframe Fix)",
  "version": "3.0",
  "description": "Filtruje plan nawet wewnątrz ramek DokuWiki",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://eclipse.elektron.pk.edu.pl/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://eclipse.elektron.pk.edu.pl/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}